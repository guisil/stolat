# Copy to .env and fill in your values. Docker Compose reads this automatically.

# Music directory on the host (mounted read-only into the container)
STOLAT_MUSIC_DIR=/path/to/your/music

# Mail (Resend)
SPRING_MAIL_HOST=smtp.resend.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=resend
SPRING_MAIL_PASSWORD=re_your_api_key
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
STOLAT_NOTIFICATION_FROM=StoLat <stolat@yourdomain.com>
STOLAT_NOTIFICATION_RECIPIENT=your-email@example.com

# Discogs
STOLAT_DISCOGS_USERNAME=
STOLAT_DISCOGS_TOKEN=

# Volumio
STOLAT_VOLUMIO_URL=http://volumio.local
