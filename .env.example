# Copy to .env and fill in your values. Docker Compose reads this automatically.

# Music directory on the host (mounted read-only into the container)
STOLAT_MUSIC_DIR=/path/to/your/music

# Mail (Gmail with app password — https://myaccount.google.com/apppasswords)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-stolat-gmail@gmail.com
SPRING_MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
STOLAT_NOTIFICATION_FROM=StoLat <your-stolat-gmail@gmail.com>
STOLAT_NOTIFICATION_RECIPIENT=your-personal-email@example.com

# Discogs (optional)
STOLAT_DISCOGS_USERNAME=
STOLAT_DISCOGS_TOKEN=

# Volumio (optional)
STOLAT_VOLUMIO_URL=http://volumio.local
# Browse http://volumio.local/api/v1/browse?uri=music-library to find your library path
STOLAT_VOLUMIO_MUSIC_LIBRARY_URI=music-library

# Last.fm (optional — https://www.last.fm/api/account/create)
STOLAT_LASTFM_API_KEY=
STOLAT_LASTFM_USERNAME=
