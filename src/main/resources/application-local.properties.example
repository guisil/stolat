# Local overrides (copy to application-local.properties and fill in your values).
# This file is gitignored.

# Mail — Resend (same account as meads, free tier: 100 emails/day)
spring.mail.host=smtp.resend.com
spring.mail.port=587
spring.mail.username=resend
spring.mail.password=
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
stolat.notification.from=StoLat <stolat@yourdomain.com>
stolat.notification.recipient=your-email@example.com

# Discogs — get a token at https://www.discogs.com/settings/developers
stolat.discogs.username=
stolat.discogs.token=

# Volumio — your Volumio instance URL (e.g., http://volumio.local or http://192.168.1.x)
stolat.volumio.url=
